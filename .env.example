# MikroTik Dashboard & MCP Server configuration

# REST API credentials for the MikroTik router
ROUTER_HOST=192.168.1.1
ROUTER_USER=MCP-User
ROUTER_PASS=secretpassword

# Dashboard port
PORT=8080

# Insecure TLS bypass if your router uses a self-signed certificate
# Set to 1 to allow insecure TLS connections bypassing local CA checks
ALLOW_INSECURE_TLS=0

# HTTPS support
# Specify paths to the private key and cert to run the dashboard on HTTPS
# SSL_KEY=./server.key
# SSL_CERT=./server.crt

# Allowed origins for API requests (Dashboard)
# CORS_ORIGIN=http://localhost:8080

# Dashboard access token (optional, leave empty for no auth)
# If set, users must enter this token to access the dashboard
# DASHBOARD_TOKEN=my-secret-token
